# ── GitHub App ──────────────────────────────────────────────────────────────
GITHUB_APP_ID=123456
# Generate: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
# Base64-encode your downloaded .pem file:
#   On Linux/Mac: base64 -w 0 your-app.private-key.pem
#   On Windows:   [Convert]::ToBase64String([IO.File]::ReadAllBytes("your-app.private-key.pem"))
GITHUB_PRIVATE_KEY=base64_encoded_pem_here
GITHUB_CLIENT_ID=Iv1.your_client_id
GITHUB_CLIENT_SECRET=your_client_secret_here

# ── Database ─────────────────────────────────────────────────────────────────
# Local:    postgresql://postgres:password@localhost:5432/deployguard
# Railway:  Provided automatically as DATABASE_URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/deployguard

# ── Redis ────────────────────────────────────────────────────────────────────
# Local:    redis://localhost:6379
# Railway:  Provided automatically as REDIS_URL
REDIS_URL=redis://localhost:6379

# ── NLP Microservice ─────────────────────────────────────────────────────────
# Local:   http://localhost:8000
# Render:  https://your-nlp-service.onrender.com
NLP_SERVICE_URL=http://localhost:8000

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Frontend (set in apps/web/.env) ──────────────────────────────────────────
# VITE_API_URL=http://localhost:3000
# VITE_GITHUB_CLIENT_ID=Iv1.your_client_id
